{
  "name": "wheelsense-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "postinstall": "node ./scripts/apply-node-patches.cjs",
    "deps:link-short": "powershell -ExecutionPolicy Bypass -File ./scripts/link-node-modules-short.ps1",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:android": "expo prebuild --platform android",
    "build:apk": "powershell -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1",
    "build:apk:eas": "eas build -p android --profile preview"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "expo": "~54.0.33",
    "expo-background-fetch": "~14.0.9",
    "expo-battery": "~10.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-sensors": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "i18next": "^26.0.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.3",
    "react-native": "0.81.5",
    "react-native-ble-plx": "^3.5.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "sp-react-native-mqtt": "^0.6.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@expo/config-plugins": "~54.0.4",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
