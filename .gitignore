# .gitignore for WheelSense Platform

# Common
.DS_Store
Thumbs.db
*.log
.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/

# Testing & Quality Tools
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Reports (keep tracked, but regenerable)
# server/reports/

# Node/Server
node_modules/
dist/

# Firmware (PlatformIO)
.pio/
.vscode/

# Docker
.docker-data/
postgres-data/
mosquitto/data/
mosquitto/log/
