# .gitignore for WheelSense Platform

# Common
.DS_Store
Thumbs.db
*.log
.env
debug-*.log
firmware/**/build_output*.txt

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/

# Testing & Quality Tools
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Reports (regenerable)
server/reports/
server/pytest_output.txt

# Runtime uploads / local storage
server/storage/

# Home Assistant runtime (keep configuration.yaml tracked separately if needed)
server/homeassistant/.storage/
server/homeassistant/deps/
server/homeassistant/tts/
server/homeassistant/*.log
server/homeassistant/*.log.*
server/homeassistant/*.fault
server/homeassistant/.ha_run.lock

# Node/Server
node_modules/
dist/

# Firmware (PlatformIO)
.pio/
.vscode/

# Docker
.docker-data/
postgres-data/
mosquitto/data/
mosquitto/log/

# Android SDK (local install under mobile-app; do not commit)
mobile-app/.android-sdk/

# Accidental literal paths (e.g. CMD %VAR% used without expansion in PowerShell)
/%USERPROFILE%/
/%USERPROFILE%AndroidSdkcmdline-tools/

# Accidental literal Windows TEMP zip (must never enter Git; exceeds GitHub limit)
/%TEMP%cmdline-tools.zip

# IDE / local build artifacts (mobile)
mobile-app/**/.idea/
mobile-app/**/*.apk

# AI/IDE agent directories
.agents/
.claude/
.cursor/
.qoder/
code_review/

# Thesis (local only, not part of platform)
Thesis/
Thesis-v2.zip
