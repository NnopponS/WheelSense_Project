# WheelSense v2.0 Environment Configuration

# ===========================================
# PostgreSQL Database
# ===========================================
DATABASE_URL=postgresql://wheelsense:wheelsense@localhost:5432/wheelsense
POSTGRES_USER=wheelsense
POSTGRES_PASSWORD=wheelsense
POSTGRES_DB=wheelsense

# ===========================================
# MQTT Configuration (for M5StickCPlus2)
# ===========================================
MQTT_BROKER=broker.emqx.io
MQTT_PORT=1883
MQTT_TOPIC=WheelSense/data
MQTT_USER=
MQTT_PASSWORD=

# ===========================================
# Home Assistant Integration
# ===========================================
HA_URL=http://localhost:8123
HA_TOKEN=your_long_lived_access_token_here

# To get HA token:
# 1. Go to your Home Assistant profile
# 2. Scroll down to "Long-Lived Access Tokens"
# 3. Create a new token


# ===========================================
# API Settings
# ===========================================
DEBUG=false
DEVICE_BACKEND_URL=
DEVICE_SERVER_IP=
STALE_DATA_SECONDS=30
NODE_TIMEOUT_SECONDS=30
WHEELCHAIR_OFFLINE_SECONDS=60
CAMERA_OFFLINE_SECONDS=30

# ===========================================
# Telemetry Sampling + Retention
# ===========================================
HISTORY_SAMPLE_INTERVAL_SECONDS=5
HISTORY_RETENTION_DAYS=7
HISTORY_RETENTION_AUTO_ENABLED=false
HISTORY_RETENTION_AUTO_INTERVAL_MINUTES=360

# ===========================================
# Ollama / AI Performance Tuning
# ===========================================
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
OLLAMA_TEMPERATURE=0.3
OLLAMA_TOP_P=0.9
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=256
OLLAMA_KEEP_ALIVE=30m
OLLAMA_RETRY_ATTEMPTS=2
OLLAMA_RETRY_BACKOFF_SECONDS=1.5

# Chat payload limits for latency control
CHAT_MAX_USER_MESSAGE_CHARS=2000
LLM_MAX_CONTEXT_CHARS=12000
LLM_WARMUP_ON_STARTUP=true
