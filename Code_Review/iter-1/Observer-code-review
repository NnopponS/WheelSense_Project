### Fix 2: Refactor Tasks Page ⬆️ High Priority

```diff
// tasks/page.tsx
-import { useQuery } from "@/hooks/useQuery";
+import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";

-  const { data: tasksData, refetch: refetchTasks, isLoading } = useQuery<ListWorkflowTasksResponse>("/workflow/tasks");
+  const queryClient = useQueryClient();
+  const { data: tasksData, isLoading } = useQuery({
+    queryKey: ["observer", "tasks", "list"],
+    queryFn: () => api.listWorkflowTasks({ limit: 300 }),
+  });

-  await api.patch(`/workflow/tasks/${taskId}`, { status: "completed", ... });
-  await refetchTasks();
+  useMutation({
+    mutationFn: (taskId: number) => api.updateWorkflowTask(taskId, { status: "completed" }),
+    onSuccess: () => {
+      void queryClient.invalidateQueries({ queryKey: ["observer", "tasks"] });
+      void queryClient.invalidateQueries({ queryKey: ["observer", "dashboard"] });
+      void queryClient.invalidateQueries({ queryKey: ["observer", "patients"] });
+    },
+  });

-  console.error("Failed to complete task:", err);
+  // Use UI error state instead
```

