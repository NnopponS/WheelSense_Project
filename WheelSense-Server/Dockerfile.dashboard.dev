# Dockerfile for Dashboard (Development with Vite)

FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY WheelSense-Dashboard/package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY WheelSense-Dashboard/ ./

# Expose Vite dev server port
EXPOSE 5173

# Start dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]






