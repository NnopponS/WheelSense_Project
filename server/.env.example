# WheelSense Server Environment
WHEELSENSE_ENV=simulation
POSTGRES_PASSWORD=wheelsense_dev
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# Required for local `uvicorn` (see server/docs/ENV.md — minimal `.env`)
# SECRET_KEY=dev-local-change-me
# Do not set BOOTSTRAP_ADMIN_PASSWORD to an empty value — Docker Compose treats that as "set" and
# overrides the compose default, so bootstrap may skip or store a bad hash. Omit the line or set a real password.
# BOOTSTRAP_ADMIN_PASSWORD=admin1234
# Optional: re-hash admin on each startup to match env (docker-compose.yml sets this to true for the stack)
# BOOTSTRAP_ADMIN_SYNC_PASSWORD=true

# GitHub OAuth App (Device Flow) — optional; enables Copilot token connect in /api/settings/ai/copilot/*
# GITHUB_OAUTH_CLIENT_ID=

# Recommended when the FastAPI server runs in Docker and Ollama runs natively on Windows/macOS.
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
