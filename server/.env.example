# WheelSense Server Environment
# ENV_MODE: production | simulator
# Production: uses wheelsense_prod database on port 5433, container wheelsense-db-prod
# Simulator: uses wheelsense_sim database on port 5432, container wheelsense-db-sim
# Both can run simultaneously with no conflicts
ENV_MODE=simulator
# Required: Database password (no default - must be set)
POSTGRES_PASSWORD=change_me_to_secure_password

# Database URLs (auto-configured based on ENV_MODE if not set)
# Production Docker (uses service name as hostname):
# DATABASE_URL=postgresql+asyncpg://wheelsense:${POSTGRES_PASSWORD}@wheelsense-db-prod:5432/wheelsense_prod
# DATABASE_URL_SYNC=postgresql://wheelsense:${POSTGRES_PASSWORD}@wheelsense-db-prod:5432/wheelsense_prod
# Sim Docker (uses service name as hostname):
# DATABASE_URL=postgresql+asyncpg://wheelsense:${POSTGRES_PASSWORD}@wheelsense-db-sim:5432/wheelsense_sim
# DATABASE_URL_SYNC=postgresql://wheelsense:${POSTGRES_PASSWORD}@wheelsense-db-sim:5432/wheelsense_sim
# Local development (uses localhost with exposed ports):
# DATABASE_URL=postgresql+asyncpg://wheelsense:${POSTGRES_PASSWORD}@localhost:5433/wheelsense_prod
# DATABASE_URL_SYNC=postgresql://wheelsense:${POSTGRES_PASSWORD}@localhost:5433/wheelsense_prod

MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# Required: JWT signing secret (no default - must be set)
SECRET_KEY=change_me_to_random_32_char_string
# Do not set BOOTSTRAP_ADMIN_PASSWORD to an empty value — Docker Compose treats that as "set" and
# overrides the compose default, so bootstrap may skip or store a bad hash. Omit the line or set a real password.
BOOTSTRAP_ADMIN_PASSWORD=change_me_to_admin_password
# Required: Internal service authentication secret (no default - must be set)
INTERNAL_SERVICE_SECRET=change_me_to_internal_service_secret

# Optional: re-hash admin on each startup to match env (docker-compose.yml sets this to true for the stack)
BOOTSTRAP_ADMIN_SYNC_PASSWORD=true

# GitHub OAuth App (Device Flow) — optional; enables Copilot token connect in /api/settings/ai/copilot/*
# GITHUB_OAUTH_CLIENT_ID=

# Recommended when the FastAPI server runs in Docker and Ollama runs natively on Windows/macOS.
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Optional: pin MQTT synthetic simulator to a workspace (Compose passes this to wheelsense-simulator).
# Sim stack: docker compose -f docker-compose.sim.yml up --build -d  (from server/)
# SIM_WORKSPACE_ID=2

# Optional: default compose file so from server/ you can run only:
#   docker compose up --build -d
# Use sim stack:
# COMPOSE_FILE=docker-compose.sim.yml
# Production DB stack (default if unset):
# COMPOSE_FILE=docker-compose.yml
