\newcommand*{\captionsource}[3][]{%
    \caption[{#1}]{#2\\}
    {\textbf{แหล่งที่มา:} #3}%
}

%% Generic placeholder figure: #1 caption, #2 label (e.g. fig:foo), #3 suggested asset path under assets/figures/
\newcommand{\figplaceholder}[3]{%
  \begin{figure}[H]
    \centering
    \fbox{\parbox{0.85\textwidth}{\centering\vspace{2.5em}
      \textit{[ภาพประกอบ]}\\[0.3em]
      \small #1\\[0.6em]
      \texttt{\scriptsize #3}
    \vspace{2.5em}}}
    \caption{#1}\label{#2}
  \end{figure}%
}

